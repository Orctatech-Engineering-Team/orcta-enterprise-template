{
    "name": "backend",
    "version": "1.0.0",
    "description": "DDD + Hexagonal architecture TypeScript backend template",
    "type": "module",
    "main": "src/main.ts",
    "scripts": {
        "dev": "bun run --watch src/main.ts",
        "build": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "type-check": "tsc --noEmit",
        "check-types": "tsc --noEmit",
        "db:generate": "drizzle-kit generate --config drizzle.config.ts",
        "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
        "lint": "oxlint src",
        "lint:fix": "oxlint --fix src",
        "format": "oxfmt src/",
        "format:check": "oxfmt --check src/"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.2",
        "hono": "^4.12.18",
        "pino": "^10.3.1",
        "postgres": "^3.4.9",
        "ulid": "^3.0.2",
        "vite-tsconfig-paths": "^6.1.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.2",
        "bun-types": "^1.3.13",
        "dotenv": "^17.4.2",
        "drizzle-kit": "^0.31.10",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    },
    "engines": {
        "bun": ">=1.0.0",
        "node": ">=20.0.0"
    },
    "keywords": [
        "ddd",
        "hexagonal-architecture",
        "typescript",
        "template",
        "bun",
        "hono",
        "drizzle"
    ],
    "author": "",
    "license": "MIT"
}
